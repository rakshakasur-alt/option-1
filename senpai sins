        function viewCommentPost(postId) {
            const post = adminPosts.find(p => p.id === postId);
            if (post) {
                openPost(postId);
            } else {
                showAdminMessage('Post not found!', 'error');
            }
        }

        function deleteComment(commentId, postId) {
            if (!confirm('Are you sure you want to delete this comment?\n\nThis action cannot be undone.')) {
                return;
            }
            
            const allComments = JSON.parse(localStorage.getItem('postComments') || '{}');
            
            if (allComments[postId]) {
                // Remove the comment from the array
                allComments[postId] = allComments[postId].filter(comment => comment.id !== commentId);
                
                // If no comments left for this post, remove the post entry
                if (allComments[postId].length === 0) {
                    delete allComments[postId];
                }
                
                // Save updated comments
                localStorage.setItem('postComments', JSON.stringify(allComments));
                
                // Refresh the display
                displayManageComments();
                
                showAdminMessage('Comment deleted successfully! 🗑️', 'success');
            } else {
                showAdminMessage('Comment not found!', 'error');
            }
        }

        function editPost(postId) {
            const post = adminPosts.find(p => p.id === postId);
            if (!post) {
                showAdminMessage('Post not found!', 'error');
                return;
            }
            
            // Fill the edit form with current post data
            document.getElementById('edit-post-id').value = post.id;
            document.getElementById('edit-post-title').value = post.title;
            document.getElementById('edit-post-image').value = post.imageUrl;
            document.getElementById('edit-post-description').value = post.description;
            document.getElementById('edit-video-type').value = post.videoType || 'direct';
            
            // Show appropriate video input fields
            toggleEditVideoInputs();
            
            // Fill video content based on type
            if (post.videoType === 'embed' && post.embedCode) {
                document.getElementById('edit-embed-code').value = post.embedCode;
            } else if (post.videoUrl) {
                document.getElementById('edit-video-url').value = post.videoUrl;
            }
            
            // Show the edit popup
            document.getElementById('edit-post-popup').style.display = 'flex';
        }

        function closeEditPopup() {
            document.getElementById('edit-post-popup').style.display = 'none';
            document.getElementById('edit-post-form').reset();
        }

        function toggleEditVideoInputs() {
            const videoType = document.getElementById('edit-video-type').value;
            const urlGroup = document.getElementById('edit-video-url-group');
            const embedGroup = document.getElementById('edit-embed-code-group');
            const videoUrl = document.getElementById('edit-video-url');
            const embedCode = document.getElementById('edit-embed-code');
            
            // Hide all groups first
            urlGroup.style.display = 'none';
            embedGroup.style.display = 'none';
            
            // Remove required attributes
            videoUrl.removeAttribute('required');
            embedCode.removeAttribute('required');
            
            // Show appropriate group and set required
            if (videoType === 'mega' || videoType === 'direct') {
                urlGroup.style.display = 'flex';
                videoUrl.setAttribute('required', 'required');
                
                // Update placeholder based on type
                if (videoType === 'mega') {
                    videoUrl.placeholder = 'https://mega.nz/file/...';
                } else {
                    videoUrl.placeholder = 'https://example.com/video.mp4';
                }
            } else if (videoType === 'embed') {
                embedGroup.style.display = 'flex';
                embedCode.setAttribute('required', 'required');
            }
        }

        function updatePost(event) {
            event.preventDefault();
            
            const postId = document.getElementById('edit-post-id').value;
            const postIndex = adminPosts.findIndex(p => p.id === postId);
            
            if (postIndex === -1) {
                showAdminMessage('Post not found!', 'error');
                return;
            }
            
            const videoType = document.getElementById('edit-video-type').value;
            let videoContent = '';
            
            if (videoType === 'embed') {
                videoContent = document.getElementById('edit-embed-code').value.trim();
            } else {
                videoContent = document.getElementById('edit-video-url').value.trim();
            }
            
            // Validate required fields
            if (!videoContent) {
                showAdminMessage('Please provide video content', 'error');
                return;
            }
            
            // Update the post
            adminPosts[postIndex] = {
                ...adminPosts[postIndex],
                title: document.getElementById('edit-post-title').value.trim(),
                imageUrl: document.getElementById('edit-post-image').value.trim(),
                description: document.getElementById('edit-post-description').value.trim(),
                videoType: videoType,
                videoUrl: videoType !== 'embed' ? videoContent : adminPosts[postIndex].videoUrl,
                embedCode: videoType === 'embed' ? videoContent : adminPosts[postIndex].embedCode,
                updatedAt: new Date().toISOString()
            };
            
            // Clear unused fields
            if (videoType === 'embed') {
                adminPosts[postIndex].videoUrl = '';
            } else {
                adminPosts[postIndex].embedCode = '';
            }
            
            // Save to localStorage
            localStorage.setItem('adminPosts', JSON.stringify(adminPosts));
            
            // Update displays
            displayPosts();
            displayManagePosts();
            
            // Close popup and show success message
            closeEditPopup();
            showAdminMessage(`Post "${adminPosts[postIndex].title}" updated successfully! ✅`, 'success');
        }

        function deletePost(postId) {
            const post = adminPosts.find(p => p.id === postId);
            if (!post) {
                showAdminMessage('Post not found!', 'error');
                return;
            }
            
            // Confirm deletion
            if (!confirm(`Are you sure you want to delete "${post.title}"?\n\nThis action cannot be undone.`)) {
                return;
            }
            
            // Remove from array
            adminPosts = adminPosts.filter(p => p.id !== postId);
            
            // Save to localStorage
            localStorage.setItem('adminPosts', JSON.stringify(adminPosts));
            
            // Update displays
            displayPosts();
            updateAdminStats();
            
            showAdminMessage(`Post "${post.title}" deleted successfully! 🗑️`, 'success');
        }

