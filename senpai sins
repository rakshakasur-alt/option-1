        function generateExcelFile() {
            // Prepare data for Excel export
            const exportData = [];
            
            // Add header row
            exportData.push([
                'Post ID',
                'Title',
                'Description',
                'Thumbnail URL',
                'Video URL',
                'Video Type',
                'Views',
                'Likes',
                'Dislikes',
                'Comments Count',
                'Created Date',
                'Last Updated'
            ]);
            
            // Calculate total views and comments
            let totalViews = 0;
            let totalComments = 0;
            const allComments = JSON.parse(localStorage.getItem('postComments') || '{}');
            
            // Add data rows
            adminPosts.forEach(post => {
                const stats = getVideoStats(post.id);
                const postComments = allComments[post.id] || [];
                const commentCount = postComments.length;
                
                totalViews += stats.views;
                totalComments += commentCount;
                
                exportData.push([
                    post.id,
                    post.title,
                    post.description,
                    post.imageUrl,
                    post.videoUrl || post.embedCode || 'N/A',
                    post.videoType || 'direct',
                    stats.views,
                    stats.likes,
                    stats.dislikes,
                    commentCount,
                    new Date(post.createdAt).toLocaleDateString(),
                    post.updatedAt ? new Date(post.updatedAt).toLocaleDateString() : 'N/A'
                ]);
            });
            
            // Add summary row
            exportData.push([]);
            exportData.push([
                'SUMMARY',
                `Total Posts: ${adminPosts.length}`,
                `Total Views: ${totalViews}`,
                `Total Comments: ${totalComments}`,
                `Export Date: ${new Date().toLocaleDateString()}`,
                `Export Time: ${new Date().toLocaleTimeString()}`,
                '',
                '',
                '',
                '',
                '',
                ''
            ]);
            
            // Convert to CSV format (Excel compatible)
            const csvContent = exportData.map(row => 
                row.map(cell => {
                    // Escape quotes and wrap in quotes if contains comma, quote, or newline
                    const cellStr = String(cell || '');
                    if (cellStr.includes(',') || cellStr.includes('"') || cellStr.includes('\n')) {
                        return '"' + cellStr.replace(/"/g, '""') + '"';
                    }
                    return cellStr;
                }).join(',')
            ).join('\n');
            
            // Add BOM for proper Excel UTF-8 handling
            const BOM = '\uFEFF';
            const csvWithBOM = BOM + csvContent;
            
            // Create and download file
            const blob = new Blob([csvWithBOM], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            
            link.setAttribute('href', url);
            link.setAttribute('download', `MyGallery_Data_Export_${new Date().toISOString().split('T')[0]}.csv`);
            link.style.visibility = 'hidden';
            
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            // Clean up
            URL.revokeObjectURL(url);
        }

