        // Video stats functions
        function initializeVideoStats(postId) {
            // Load existing stats from localStorage
            const stats = getVideoStats(postId);
            
            // Update display
            document.getElementById(`like-count-${postId}`).textContent = stats.likes;
            document.getElementById(`dislike-count-${postId}`).textContent = stats.dislikes;
            document.getElementById(`view-count-${postId}`).textContent = formatViewCount(stats.views);
            
            // Increment view count
            stats.views++;
            saveVideoStats(postId, stats);
            document.getElementById(`view-count-${postId}`).textContent = formatViewCount(stats.views);
            
            // Update button states
            updateButtonStates(postId);
        }

        function getVideoStats(postId) {
            const allStats = JSON.parse(localStorage.getItem('videoStats') || '{}');
            return allStats[postId] || { likes: 0, dislikes: 0, views: 0, userLiked: false, userDisliked: false };
        }

        function saveVideoStats(postId, stats) {
            const allStats = JSON.parse(localStorage.getItem('videoStats') || '{}');
            allStats[postId] = stats;
            localStorage.setItem('videoStats', JSON.stringify(allStats));
        }

        function toggleLike(postId) {
            const stats = getVideoStats(postId);
            
            if (stats.userLiked) {
                // Remove like
                stats.likes--;
                stats.userLiked = false;
            } else {
                // Add like
                stats.likes++;
                stats.userLiked = true;
                
                // Remove dislike if it exists
                if (stats.userDisliked) {
                    stats.dislikes--;
                    stats.userDisliked = false;
                }
            }
            
            saveVideoStats(postId, stats);
            updateDisplay(postId, stats);
            updateButtonStates(postId);
            
            // Add animation effect
            const likeBtn = document.getElementById(`like-btn-${postId}`);
            likeBtn.style.transform = 'scale(1.1)';
            setTimeout(() => {
                likeBtn.style.transform = 'scale(1)';
            }, 200);
        }

        function toggleDislike(postId) {
            const stats = getVideoStats(postId);
            
            if (stats.userDisliked) {
                // Remove dislike
                stats.dislikes--;
                stats.userDisliked = false;
            } else {
                // Add dislike
                stats.dislikes++;
                stats.userDisliked = true;
                
                // Remove like if it exists
                if (stats.userLiked) {
                    stats.likes--;
                    stats.userLiked = false;
                }
            }
            
            saveVideoStats(postId, stats);
            updateDisplay(postId, stats);
            updateButtonStates(postId);
            
            // Add animation effect
            const dislikeBtn = document.getElementById(`dislike-btn-${postId}`);
            dislikeBtn.style.transform = 'scale(1.1)';
            setTimeout(() => {
                dislikeBtn.style.transform = 'scale(1)';
            }, 200);
        }

        function updateDisplay(postId, stats) {
            document.getElementById(`like-count-${postId}`).textContent = stats.likes;
            document.getElementById(`dislike-count-${postId}`).textContent = stats.dislikes;
            document.getElementById(`view-count-${postId}`).textContent = formatViewCount(stats.views);
        }

        function updateButtonStates(postId) {
            const stats = getVideoStats(postId);
            const likeBtn = document.getElementById(`like-btn-${postId}`);
            const dislikeBtn = document.getElementById(`dislike-btn-${postId}`);
            
            // Update like button
            if (stats.userLiked) {
                likeBtn.style.background = 'linear-gradient(45deg, rgba(0, 255, 0, 0.4), rgba(0, 200, 0, 0.4))';
                likeBtn.style.borderColor = 'rgba(0, 255, 0, 0.6)';
                likeBtn.style.boxShadow = '0 0 20px rgba(0, 255, 0, 0.4)';
            } else {
                likeBtn.style.background = 'linear-gradient(45deg, rgba(0, 255, 0, 0.2), rgba(0, 200, 0, 0.2))';
                likeBtn.style.borderColor = 'rgba(0, 255, 0, 0.3)';
                likeBtn.style.boxShadow = 'none';
            }
            
            // Update dislike button
            if (stats.userDisliked) {
                dislikeBtn.style.background = 'linear-gradient(45deg, rgba(255, 0, 0, 0.4), rgba(200, 0, 0, 0.4))';
                dislikeBtn.style.borderColor = 'rgba(255, 0, 0, 0.6)';
                dislikeBtn.style.boxShadow = '0 0 20px rgba(255, 0, 0, 0.4)';
            } else {
                dislikeBtn.style.background = 'linear-gradient(45deg, rgba(255, 0, 0, 0.2), rgba(200, 0, 0, 0.2))';
                dislikeBtn.style.borderColor = 'rgba(255, 0, 0, 0.3)';
                dislikeBtn.style.boxShadow = 'none';
            }
        }

