                            src += separator + 'quality=1080p';
                        }
                        if (!src.includes('autopause=')) {
                            src += '&autopause=0';
                        }
                    }
                    
                    // Apply enhanced src
                    iframe.src = src;
                });
                
                // Initialize like/dislike data and increment view count
                initializeVideoStats(post.id);
                
