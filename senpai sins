                            <p style="color: rgba(255, 255, 255, 0.8); line-height: 1.6; font-size: 1rem;">${post.description}</p>
                            <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                                <small style="color: rgba(255, 255, 255, 0.6);">📅 Added: ${new Date(post.createdAt).toLocaleDateString()}</small>
                            </div>
