        // Age verification functions
        function verifyAge() {
            const nameInput = document.getElementById('user-name');
            const ageInput = document.getElementById('user-age');
            const errorDiv = document.getElementById('error-message');
            
            const name = nameInput.value.trim();
            const age = parseInt(ageInput.value);
            
            // Clear any previous errors
            errorDiv.style.display = 'none';
            errorDiv.textContent = '';
            
            // Validate name
            if (!name) {
                showError('Please enter your name.');
                return;
            }
            
            // Validate age
            if (!ageInput.value || isNaN(age) || age < 1 || age > 120) {
                showError('Please enter a valid age.');
                return;
            }
            
            if (age < 18) {
                showError('You must be 18 or older to access this site.');
                return;
            }
            
            // Store user info
            userName = name;
            userAge = age;
            
            // Hide popup and show main content
            document.getElementById('age-verification').style.display = 'none';
            
            // Initialize the site
            initializeSite();
        }

        function showError(message) {
            const errorDiv = document.getElementById('error-message');
            errorDiv.textContent = message;
            errorDiv.style.display = 'block';
        }

        function exitSite() {
            alert('Thank you for being honest. Please visit age-appropriate content.');
            window.close();
        }

        function initializeSite() {
            // Site is now accessible
            console.log(`Welcome ${userName}! Age: ${userAge}`);
            
            // Save verification status to localStorage
            localStorage.setItem('ageVerified', 'true');
            localStorage.setItem('userName', userName);
            localStorage.setItem('userAge', userAge);
            
            loadAdminPosts();
        }

        // Check if user is already verified on page load
        function checkAgeVerification() {
            const isVerified = localStorage.getItem('ageVerified');
            const savedName = localStorage.getItem('userName');
            const savedAge = localStorage.getItem('userAge');
            
            if (isVerified === 'true' && savedName && savedAge) {
                // User is already verified
                userName = savedName;
                userAge = parseInt(savedAge);
                document.getElementById('age-verification').style.display = 'none';
                loadAdminPosts();
                return true;
            }
            return false;
        }

        // Admin functions
        function showAdminLogin() {
            if (isAdminLoggedIn) {
                showSection('admin-section');
                return;
            }
            document.getElementById('admin-login').style.display = 'flex';
        }

        function closeAdminLogin() {
            document.getElementById('admin-login').style.display = 'none';
            document.getElementById('admin-login-error').style.display = 'none';
            document.getElementById('admin-username').value = '';
            document.getElementById('admin-password').value = '';
        }

        function adminLogin() {
            const username = document.getElementById('admin-username').value.trim();
            const password = document.getElementById('admin-password').value;
            const errorDiv = document.getElementById('admin-login-error');

            if (!username || !password) {
                showAdminError('Please enter both username and password.');
                return;
            }

            if (username === ADMIN_CREDENTIALS.username && password === ADMIN_CREDENTIALS.password) {
                isAdminLoggedIn = true;
                closeAdminLogin();
                showSection('admin-section');
                showAdminMessage('Welcome back, Admin! 🎉', 'success');
                updateAdminStats();
            } else {
                showAdminError('Invalid username or password. Please try again.');
                document.getElementById('admin-password').value = '';
            }
        }

        function adminLogout() {
            if (confirm('Are you sure you want to logout?')) {
                isAdminLoggedIn = false;
                showSection('home-section');
                showAdminMessage('Logged out successfully. See you later! 👋', 'success');
            }
        }

        function showAdminError(message) {
            const errorDiv = document.getElementById('admin-login-error');
            errorDiv.textContent = message;
            errorDiv.style.display = 'block';
        }

        function showAdminMessage(message, type) {
            const messageDiv = document.getElementById('admin-message');
            messageDiv.className = type === 'success' ? 'success-message' : 'admin-error-message';
            messageDiv.textContent = message;
            messageDiv.style.display = 'block';
            
            setTimeout(() => {
                messageDiv.style.display = 'none';
            }, 5000);
        }

        // Post management functions
        function addNewPost(event) {
            event.preventDefault();
            
            const videoType = document.getElementById('video-type').value;
            let videoContent = '';
            
            if (videoType === 'embed') {
                videoContent = document.getElementById('embed-code').value.trim();
            } else {
                videoContent = document.getElementById('video-url').value.trim();
            }
            
            const postData = {
                id: 'post_' + Date.now(),
                title: document.getElementById('post-title').value.trim(),
                imageUrl: document.getElementById('post-image').value.trim(),
                description: document.getElementById('post-description').value.trim(),
                videoType: videoType,
                videoUrl: videoType !== 'embed' ? videoContent : '',
                embedCode: videoType === 'embed' ? videoContent : '',
                createdAt: new Date().toISOString()
            };

            // Validate required fields
            if (!postData.title || !postData.imageUrl || !postData.description || !videoContent || !videoType) {
                showAdminMessage('Please fill in all required fields', 'error');
                return;
            }

            // Add to posts array
            adminPosts.push(postData);
            
            // Save to localStorage
            localStorage.setItem('adminPosts', JSON.stringify(adminPosts));
            
            // Update stats and display
            updateAdminStats();
            displayPosts();
            
            // Clear form
            document.querySelector('.admin-form').reset();
            
            showAdminMessage(`Post "${postData.title}" added successfully! 🎉`, 'success');
        }

        function loadAdminPosts() {
            const savedPosts = localStorage.getItem('adminPosts');
            if (savedPosts) {
                adminPosts = JSON.parse(savedPosts);
            }
            displayPosts();
            updateAdminStats();
        }

        function displayPosts() {
            const galleryContainer = document.getElementById('gallery-container');
            
            if (adminPosts.length === 0) {
                galleryContainer.innerHTML = `
                    <div class="no-posts-message">
                        <h3>No Posts Yet</h3>
                        <p>Add your first post through the Admin panel to get started!</p>
                    </div>
                `;
                return;
            }
            
            galleryContainer.innerHTML = adminPosts.map(post => `
                <div class="post-cylinder" onclick="openPost('${post.id}')">
                    <div class="cylinder-glow"></div>
                    <div class="cylinder-content">
                        <div class="post-image">
                            <img src="${post.imageUrl}" alt="${post.title}" onerror="this.src=''; this.alt='Image failed to load'; this.style.display='none'; this.parentElement.innerHTML='📷';">
                        </div>
                        <div class="post-info">
                            <div class="post-title">${post.title}</div>
                            <div class="post-description">${post.description}</div>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function openPost(postId) {
            const post = adminPosts.find(p => p.id === postId);
            if (post) {
                showVideoPlayer(post);
            }
        }

        function showVideoPlayer(post) {
            // Show video player section
            showSection('video-player-section');
            
            // Update video player content
            document.getElementById('video-title').textContent = post.title;
            document.getElementById('video-description').textContent = post.description;
            document.getElementById('video-thumbnail').src = post.imageUrl;
            document.getElementById('video-thumbnail').alt = post.title;
            
            // Handle video content based on type
            const videoContainer = document.getElementById('video-container');
            const videoType = post.videoType || 'direct'; // Default to direct for backward compatibility
            
            if (videoType === 'embed' && post.embedCode) {
                // For embed codes (YouTube, Vimeo, etc.) - Direct embed without wrapper
                videoContainer.innerHTML = `
                    <div style="position: relative; width: 100%; height: 0; padding-bottom: 56.25%; /* 16:9 aspect ratio */">
                        <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 15px; overflow: hidden;">
                            ${post.embedCode}
                        </div>
                    </div>
                    
                    <!-- Video Controls and Description -->
                    <div style="display: flex; gap: 30px; margin-top: 25px; align-items: flex-start;">
                        <!-- Description Section (Left) -->
                        <div style="flex: 1; background: rgba(255, 255, 255, 0.05); border-radius: 15px; padding: 20px; border: 1px solid rgba(255, 255, 255, 0.1);">
