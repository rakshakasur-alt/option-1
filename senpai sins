                            💬 Comments <span id="comment-count-${post.id}" style="font-size: 0.9rem; color: rgba(255, 255, 255, 0.6);">(0)</span>
                        </h4>
                        
                        <!-- Add Comment Form -->
                        <div style="margin-bottom: 25px;">
                            <div style="display: flex; gap: 15px; margin-bottom: 15px;">
