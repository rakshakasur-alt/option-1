            adminPosts.forEach(post => {
                const stats = getVideoStats(post.id);
                totalViews += stats.views;
            });
            
            // Format the number for display
            const formattedViews = totalViews >= 1000 ? 
                (totalViews >= 1000000 ? (totalViews / 1000000).toFixed(1) + 'M' : 
                (totalViews / 1000).toFixed(1) + 'K') : totalViews.toString();
            
            document.getElementById('total-views').textContent = formattedViews;
            
            displayManagePosts();
            displayManageComments();
            updateExportStats();
