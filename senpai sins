        function updateExportStats() {
            // Update export statistics
            const allComments = JSON.parse(localStorage.getItem('postComments') || '{}');
            let totalComments = 0;
            Object.values(allComments).forEach(comments => {
                totalComments += comments.length;
            });

            let totalViews = 0;
            adminPosts.forEach(post => {
                const stats = getVideoStats(post.id);
                totalViews += stats.views;
            });

            document.getElementById('export-posts-count').textContent = adminPosts.length;
            document.getElementById('export-views-count').textContent = formatViewCount(totalViews);
