                                <span>👍</span>
                                <span id="like-count-${post.id}">0</span>
                            </button>
                            
                            <button onclick="toggleDislike('${post.id}')" id="dislike-btn-${post.id}" style="background: linear-gradient(45deg, rgba(255, 0, 0, 0.2), rgba(200, 0, 0, 0.2)); border: 2px solid rgba(255, 0, 0, 0.3); color: white; padding: 12px 20px; border-radius: 25px; cursor: pointer; font-size: 1rem; font-weight: bold; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 8px;">
                                <span>👎</span>
                                <span id="dislike-count-${post.id}">0</span>
                            </button>
                            
                            <div style="background: rgba(255, 255, 255, 0.05); border-radius: 15px; padding: 15px; text-align: center; border: 1px solid rgba(255, 255, 255, 0.1);">
                                <div style="color: rgba(255, 255, 255, 0.6); font-size: 0.9rem; margin-bottom: 5px;">👁️ Views</div>
                                <div style="color: white; font-size: 1.2rem; font-weight: bold;" id="view-count-${post.id}">0</div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Comments Section -->
                    <div style="margin-top: 30px; background: rgba(255, 255, 255, 0.05); border-radius: 15px; padding: 25px; border: 1px solid rgba(255, 255, 255, 0.1);">
