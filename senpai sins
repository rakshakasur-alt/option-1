<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram Gallery - Version 11</title>
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
    <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
            font-family: 'Arial', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Age Verification Popup */
        .age-verification-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(15px);
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .age-verification-popup {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            border: 2px solid rgba(255, 0, 110, 0.3);
            border-radius: 20px;
            padding: 40px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 60px rgba(255, 0, 110, 0.4);
            position: relative;
            overflow: hidden;
        }

        .popup-title {
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .popup-warning {
            color: #ff006e;
            font-size: 1.1rem;
            font-weight: bold;
            margin-bottom: 30px;
            text-shadow: 0 0 10px rgba(255, 0, 110, 0.5);
        }

        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .form-label {
            color: white;
            font-size: 1rem;
            margin-bottom: 8px;
            display: block;
        }

        .form-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            padding: 12px 15px;
            color: white;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-input:focus {
            outline: none;
            border-color: rgba(255, 0, 110, 0.5);
            box-shadow: 0 0 20px rgba(255, 0, 110, 0.3);
        }

        .form-input::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .popup-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
            margin-top: 30px;
        }

        .popup-btn {
            background: linear-gradient(45deg, #ff006e, #8338ec);
            border: none;
            color: white;
            padding: 12px 30px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: bold;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(255, 0, 110, 0.3);
        }

        .popup-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(255, 0, 110, 0.5);
        }

        .popup-btn.cancel {
            background: linear-gradient(45deg, #666, #888);
        }

        .error-message {
            color: #ff4444;
            font-size: 0.9rem;
            margin-top: 15px;
            text-align: center;
            background: rgba(255, 68, 68, 0.1);
            padding: 10px;
            border-radius: 8px;
            border: 1px solid rgba(255, 68, 68, 0.3);
            display: none;
        }

        /* Admin Login Popup */
        .admin-login-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(15px);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: center;
        }

        .admin-login-form {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            border: 2px solid rgba(255, 0, 110, 0.3);
            border-radius: 20px;
            padding: 40px;
            max-width: 400px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 60px rgba(255, 0, 110, 0.4);
            position: relative;
            overflow: hidden;
        }

        .admin-title {
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 2rem;
            font-weight: bold;
            margin-bottom: 30px;
        }

        .admin-input-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .admin-label {
            color: white;
            font-size: 1rem;
            margin-bottom: 8px;
            display: block;
        }

        .admin-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            padding: 12px 15px;
            color: white;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .admin-input:focus {
            outline: none;
            border-color: rgba(255, 0, 110, 0.5);
            box-shadow: 0 0 20px rgba(255, 0, 110, 0.3);
        }

        .admin-input::placeholder {
            color: rgba(255, 255, 255, 0.5);
        }

        .admin-btn {
            background: linear-gradient(45deg, #ff006e, #8338ec);
            border: none;
            color: white;
            padding: 12px 30px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 1rem;
            font-weight: bold;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(255, 0, 110, 0.3);
            width: 100%;
            margin-top: 10px;
        }

        .admin-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(255, 0, 110, 0.5);
        }

        .admin-btn.cancel {
            background: linear-gradient(45deg, #666, #888);
            margin-top: 10px;
        }

        /* Admin Panel Styles */
        .admin-panel {
            padding: 120px 20px 40px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .admin-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .admin-header h2 {
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .admin-logout {
            background: linear-gradient(45deg, rgba(255, 0, 0, 0.3), rgba(200, 0, 0, 0.3));
            border: 2px solid rgba(255, 0, 0, 0.5);
            color: white;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            position: fixed;
            top: 90px;
            right: 20px;
            z-index: 999;
        }

        .admin-logout:hover {
            background: linear-gradient(45deg, rgba(255, 0, 0, 0.5), rgba(200, 0, 0, 0.5));
            transform: translateY(-2px);
        }

        .admin-content {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 30px;
        }

        .admin-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .admin-form-group {
            display: flex;
            flex-direction: column;
        }

        .admin-form-label {
            color: white;
            font-size: 1rem;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .admin-form-input {
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            padding: 12px 15px;
            color: white;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .admin-form-input:focus {
            outline: none;
            border-color: rgba(255, 0, 110, 0.5);
            box-shadow: 0 0 20px rgba(255, 0, 110, 0.3);
        }

        .admin-form-textarea {
            min-height: 100px;
            resize: vertical;
            font-family: inherit;
        }

        .admin-submit-btn {
            background: linear-gradient(45deg, #ff006e, #8338ec);
            border: none;
            color: white;
            padding: 15px 40px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 1.1rem;
            font-weight: bold;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(255, 0, 110, 0.3);
            grid-column: 1 / -1;
            justify-self: center;
            margin-top: 20px;
        }

        .admin-submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(255, 0, 110, 0.5);
        }

        .success-message {
            background: rgba(0, 255, 0, 0.2);
            border: 1px solid rgba(0, 255, 0, 0.5);
            color: #00ff00;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            text-align: center;
        }

        .admin-error-message {
            background: rgba(255, 0, 0, 0.2);
            border: 1px solid rgba(255, 0, 0, 0.5);
            color: #ff4444;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 20px;
            text-align: center;
            display: none;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Navigation */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(15, 15, 35, 0.1);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            color: white;
            font-size: 1.5rem;
            font-weight: bold;
        }

        .logo-icon {
            font-size: 2rem;
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .logo-text {
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-menu {
            display: flex;
            gap: 30px;
        }

        .nav-item {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            font-size: 1.1rem;
            font-weight: 500;
            padding: 10px 20px;
            border-radius: 25px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .nav-item::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(45deg, rgba(255, 0, 110, 0.2), rgba(131, 56, 236, 0.2), rgba(58, 134, 255, 0.2));
            transition: left 0.3s ease;
            z-index: -1;
        }

        .nav-item:hover {
            color: white;
            text-shadow: 0 0 20px rgba(255, 0, 110, 0.8);
            box-shadow: 0 0 30px rgba(255, 0, 110, 0.3);
            transform: translateY(-2px);
        }

        .nav-item:hover::before {
            left: 0;
        }

        .nav-item.active {
            color: white;
            background: linear-gradient(45deg, rgba(255, 0, 110, 0.3), rgba(131, 56, 236, 0.3));
            box-shadow: 0 0 20px rgba(255, 0, 110, 0.4);
            text-shadow: 0 0 10px rgba(255, 0, 110, 0.6);
        }

        .nav-item.active::before {
            left: 0;
        }

        /* Header */
        .header {
            text-align: center;
            padding: 120px 20px 60px;
        }

        .logo-container {
            position: relative;
            display: inline-block;
            margin-bottom: 30px;
        }

        .round-logo {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            position: relative;
            z-index: 2;
            border: 4px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 10px 30px rgba(255, 0, 110, 0.4);
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .round-logo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

        .round-logo:hover {
            transform: scale(1.1) rotate(10deg);
            box-shadow: 0 20px 50px rgba(255, 0, 110, 0.6);
        }

        .logo-glow {
            position: absolute;
            top: -20px;
            left: -20px;
            right: -20px;
            bottom: -20px;
            border-radius: 50%;
            background: linear-gradient(45deg, rgba(255, 0, 110, 0.3), rgba(131, 56, 236, 0.3), rgba(58, 134, 255, 0.3));
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            filter: blur(20px);
            z-index: 1;
        }

        .header h1 {
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 3.5rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 1.2rem;
            color: #a0a0a0;
        }

        /* Sections */
        .section {
            display: none;
            min-height: 100vh;
        }

        .section.active {
            display: block;
        }

        /* Preview Gallery */
        .preview-gallery {
            padding: 40px 20px;
            max-width: 1200px;
            margin: 0 auto;
            overflow: hidden;
        }

        .gallery-scroll {
            display: flex;
            gap: 30px;
            animation: scroll 20s linear infinite;
            width: fit-content;
        }

        .preview-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            min-width: 120px;
        }

        .preview-image {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: linear-gradient(45deg, rgba(255, 0, 110, 0.3), rgba(131, 56, 236, 0.3), rgba(58, 134, 255, 0.3));
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            border: 3px solid rgba(255, 255, 255, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            backdrop-filter: blur(10px);
            position: relative;
            box-shadow: 0 0 20px rgba(255, 0, 110, 0.4);
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .preview-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }

        .preview-label {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            font-weight: 500;
        }

        @keyframes scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Watch Button */
        .watch-button-container {
            text-align: center;
            padding: 60px 20px;
        }

        .watch-posts-btn {
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            border: none;
            padding: 20px 40px;
            border-radius: 50px;
            color: white;
            font-size: 1.2rem;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 15px;
            margin: 0 auto;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(255, 0, 110, 0.4);
        }

        .watch-posts-btn:hover {
            transform: scale(1.05) translateY(-5px);
            box-shadow: 0 20px 50px rgba(255, 0, 110, 0.6);
        }

        /* Posts Section */
        .posts-header {
            text-align: center;
            padding: 120px 20px 40px;
        }

        .posts-header h2 {
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 3rem;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .posts-header p {
            font-size: 1.2rem;
            color: #a0a0a0;
        }

        /* Gallery Container */
        .gallery-container {
            padding: 40px 20px;
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        /* Cylindrical Posts */
        .post-cylinder {
            position: relative;
            height: 400px;
            border-radius: 20px;
            background: linear-gradient(45deg, #ff006e, #8338ec);
            box-shadow: 0 10px 30px rgba(255, 0, 110, 0.3);
            overflow: hidden;
            cursor: pointer;
            transition: all 0.4s ease;
            transform-style: preserve-3d;
        }

        .post-cylinder:nth-child(even) {
            background: linear-gradient(45deg, #3a86ff, #06ffa5);
            box-shadow: 0 10px 30px rgba(58, 134, 255, 0.3);
        }

        .post-cylinder:nth-child(3n) {
            background: linear-gradient(45deg, #ffbe0b, #fb5607);
            box-shadow: 0 10px 30px rgba(255, 190, 11, 0.3);
        }

        .post-cylinder:hover {
            transform: rotateX(10deg) scale(1.05);
            box-shadow: 0 20px 50px rgba(255, 0, 110, 0.5);
        }

        .cylinder-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            height: 100%;
            padding: 30px;
            position: relative;
            z-index: 2;
            text-align: center;
        }

        .post-image {
            width: 120px;
            height: 120px;
            border-radius: 15px;
            background: linear-gradient(45deg, rgba(255, 0, 110, 0.3), rgba(131, 56, 236, 0.3), rgba(58, 134, 255, 0.3));
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            border: 3px solid rgba(255, 255, 255, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            margin-bottom: 20px;
            backdrop-filter: blur(10px);
            position: relative;
            box-shadow: 0 0 20px rgba(255, 0, 110, 0.4);
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .post-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 12px;
        }

        .post-image:hover {
            transform: scale(1.1);
            box-shadow: 0 0 30px rgba(255, 0, 110, 0.6);
        }

        .post-info {
            flex: 1;
            color: white;
        }

        .post-title {
            font-size: 1.4rem;
            font-weight: bold;
            margin-bottom: 5px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
        }

        .post-description {
            font-size: 0.9rem;
            opacity: 0.9;
            line-height: 1.4;
        }

        .cylinder-glow {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: 20px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            animation: shimmer 3s ease-in-out infinite;
        }

        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        /* No Posts Message */
        .no-posts-message {
            text-align: center;
            color: rgba(255, 255, 255, 0.7);
            padding: 60px 20px;
            font-size: 1.2rem;
        }

        .no-posts-message h3 {
            font-size: 2rem;
            margin-bottom: 20px;
            background: linear-gradient(45deg, #ff006e, #8338ec, #3a86ff);
            background-size: 300% 300%;
            animation: gradientShift 4s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Footer */
        .footer {
            background: rgba(15, 15, 35, 0.9);
            backdrop-filter: blur(20px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding: 40px 20px 20px;
            margin-top: 60px;
        }

        .footer-container {
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        .social-buttons {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 30px;
        }

        .social-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(45deg, rgba(255, 0, 110, 0.2), rgba(131, 56, 236, 0.2));
            border: 2px solid rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: white;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .social-btn:hover {
            transform: scale(1.1) translateY(-5px);
            box-shadow: 0 10px 30px rgba(255, 0, 110, 0.4);
            background: linear-gradient(45deg, rgba(255, 0, 110, 0.4), rgba(131, 56, 236, 0.4));
        }

        .footer-text {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.9rem;
            line-height: 1.6;
            margin-bottom: 10px;
        }

        .copyright {
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.8rem;
